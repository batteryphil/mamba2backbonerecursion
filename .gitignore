# Mamba Latent Reasoning Engine — .gitignore

# Model checkpoints (too large for git)
checkpoints/
*.pth
*.safetensors
*.bin

# Session state
sessions/

# Training data (generated by build scripts)
data/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
grpo_env/

# Logs (training logs committed explicitly when needed)
wandb/
monitor.log
daemon_watch.log

# Jupyter
*.ipynb_checkpoints

# Debug / temp outputs
latent_diagnostics.jsonl
training_report.json

# Large binary artifacts
checkpoints/gguf/
checkpoints/mamba-tiny-refinement-BF16-MASTER.bak/
checkpoints/mamba-tiny-refinement-BF16-MASTER/
checkpoints/lora-step*/

# Training data (large generative files — keep in jsonl but not bin)
combined_training_data.jsonl
training_data.jsonl
targeted_samples.jsonl

# OS
.DS_Store
nohup.out
